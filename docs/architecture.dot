digraph CICD_Azure_PHP {
    rankdir=LR;
    fontname="Arial";

    node [shape=rectangle, style=filled, fontname="Arial"];

    # Developer
    dev [label="👨‍💻 Developer\n(Code Changes)", shape=oval, color=lightgreen];

    # GitHub
    github [label="GitHub Repository\n(PHP Source Code)", color=lightblue];
    actions [label="GitHub Actions\n(CI/CD Pipeline)", color=lightblue];

    # Build Stage
    build [label="Build Stage\n(Checkout + Package)", color=lightyellow];

    # Artifact
    artifact [label="Artifact (app.zip)", color=lightgrey];

    # Azure App Service
    staging [label="Azure App Service\nStaging Slot", color=orange];
    production [label="Azure App Service\nProduction Slot", color=orange];

    # Azure DNS
    dns [label="Azure DNS Zone\nauemeribetech.com.ng", color=lightcyan];

    # Custom Domain
    domain [label="Custom Domain\nwww.auemeribetech.com.ng", color=lightcyan];

    # User
    user [label="🌍 End User (Browser)", shape=oval, color=lightgreen];

    # Flow
    dev -> github [label="git push"];
    github -> actions [label="Trigger Workflow"];
    actions -> build [label="Build Job"];
    build -> artifact [label="Package App"];
    artifact -> staging [label="Deploy"];
    staging -> production [label="Slot Swap\n(Zero Downtime)"];

    production -> dns [label="App Binding"];
    dns -> domain [label="CNAME + TXT"];
    domain -> user [label="HTTPS Request"];

    # Azure grouping
    subgraph cluster_azure {
        label="Microsoft Azure";
        style=dashed;

        staging;
        production;
        dns;
    }

    # CI/CD grouping
    subgraph cluster_github {
        label="GitHub";
        style=dashed;

        github;
        actions;
        build;
        artifact;
    }
}
